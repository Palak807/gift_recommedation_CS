# LiteLLM proxy (required)
LITELLM_BASE_URL=https://xc-alb-dev-v2-litellm.xcaliberapis.com
LITELLM_API_KEY=sk-...
LITELLM_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Product search (required)
SERP_API_KEY=your_serpapi_key_here

# Langfuse tracing (optional — leave blank to disable)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# Redis caching (optional — leave blank to disable)
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=86400

# Pipeline tuning (optional)
MAX_SEARCH_RETRIES=2
MIN_VALID_PRODUCTS=3
